# ============================================================
# CONFIGURACIÓN DE PRODUCCIÓN - RifaPlus Backend
# ============================================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo a .env: cp .env.example .env
# 2. Completar TODOS los valores (especialmente JWT_SECRET)
# 3. NUNCA commitear .env (está en .gitignore)
# 4. Usar valores DIFERENTES para cada entorno (dev, staging, prod)
#
# ============================================================

# ===== CRÍTICO - DEBE ESTAR EN .env =====

# JWT Secret para firmar tokens de autenticación
# IMPORTANTE: Debe ser SEGURO, LARGO y ALEATORIO en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=rifa-plus-secret-key-super-seguro-cambiar-en-produccion

# ===== ENTORNO =====

# Activa protecciones adicionales y ajusta rate limits
# Valores: 'development' | 'production'
NODE_ENV=production

# ===== SERVIDOR =====

# Puerto en el que escucha el servidor
PORT=5001

# ===== RATE LIMITING (Opcional - valores por defecto si no se especifica) =====

# Máximo de requests por 15 minutos (general)
# Dev: 100, Producción: 150
# RATE_LIMIT_MAX=150

# Máximo de intentos de login por 15 minutos
# RATE_LIMIT_LOGIN_MAX=5

# Máximo de órdenes por minuto
# Dev: 10, Producción: 15
# RATE_LIMIT_ORDENES_MAX=15

# ===== LOGGING (Opcional) =====

# Nivel de logging: 'debug' | 'info' | 'warn' | 'error'
# LOG_LEVEL=info

# ===== CLOUDINARY (Opcional, pero requerido para comprobantes/imagenes en Cloudinary) =====

# Usa una sola variable:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
#
# O usa variables separadas:
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=tu-api-key
# CLOUDINARY_API_SECRET=tu-api-secret

# ===== BASE DE DATOS (Opcional - solo si migras a PostgreSQL) =====

# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=rifaplus
# DB_PASSWORD=cambiar-en-produccion
# DB_NAME=rifaplus_db

# ============================================================
# CHECKLIST ANTES DE PRODUCCIÓN:
# ============================================================
# ✅ JWT_SECRET cambio de valor development
# ✅ NODE_ENV=production
# ✅ .env NO está commiteado
# ✅ .env está en .gitignore
# ✅ Archivo .env existe en servidor
# ✅ Permisos: chmod 600 .env
# ============================================================
