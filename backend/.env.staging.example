# Entorno ejemplo para staging aislado
# Copia este archivo a backend/.env.staging y completa valores reales.
# No reutilizar la misma DATABASE_URL de producción.

NODE_ENV=production
PORT=5001

# Debe ser una BD separada de producción
DATABASE_URL=postgresql://usuario:password@host:5432/rifas_staging

# Ajusta estos orígenes al frontend de staging
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://staging-tu-dominio.com

# Base pública de frontend staging
PUBLIC_BASE_URL=http://localhost:8080

# JWT propio de staging
JWT_SECRET=staging-reemplazar-con-un-secreto-seguro

# Cloudinary de staging
# Usa CLOUDINARY_URL o las 3 variables separadas
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Opcional: datos locales si no usas DATABASE_URL
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rifaplus_staging
